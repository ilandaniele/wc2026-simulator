# .env.example — copy to .env and fill in values
# This file is safe to commit. Never commit .env itself.
#
# Usage:
#   cp .env.example .env
#   # Edit .env as needed, then:
#   uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000

# ── Backend URL (used by frontend / tests) ────────────────────────────────────
# The FastAPI backend binds to 127.0.0.1:8000 (loopback only, never 0.0.0.0).
# Override only for tests that spin up on a different port.
BACKEND_URL=http://127.0.0.1:8000

# ── Data directory ────────────────────────────────────────────────────────────
# Path to the data/ folder containing POST.json, tourney.json, market.json.
# Default is ./data relative to the repo root. Override for isolated test runs.
DATA_DIR=./data

# ── Optional retrain token ────────────────────────────────────────────────────
# When set, POST /model/retrain requires:
#   Authorization: Bearer <RETRAIN_TOKEN>
# When unset (empty string or var not present), the retrain endpoint is open to
# any caller from the CORS allowlist (localhost only).
#
# Generate a token: openssl rand -hex 32
RETRAIN_TOKEN=

# ── Vite frontend env (prefix VITE_ to expose to browser) ────────────────────
# Set this in frontend/.env (not repo root .env) for Vite to pick it up.
# Documented here for discoverability; Vite reads frontend/.env by default.
# VITE_BACKEND_URL=http://127.0.0.1:8000
